# ==========================================
# Next-Auth (身份验证) 配置项
# ==========================================

# 必须：Next-Auth 安全密钥（用于加密/签名会话令牌）
# 可在此生成并填入一个安全的随机文本或密钥字符串。
AUTH_SECRET=00Fv/YUm0enwy04IgP4KoNOWLODe2iJ1tvBzr+4kEZ8=

# 可选：Next-Auth 运行时的应用程序官方标准规范 URL
# AUTH_URL=https://your-domain.com

# 可选：自定义管理员密码（用户名固定为 'admin'；若留空，密码默认系统采用 'admin'）
BASIC_PASS=admin

# 可选：自定义普通访客密码（用户名固定为 'user'；若留空，密码默认系统采用 'user'）
REGULAR_PASS=user


# ==========================================
# 功能特性开关与 API 配置
# ==========================================

# 是否启用普通访客对上传功能的身份认证鉴权 (true/false，默认为 false)
ENABLE_AUTH_API=false

# 是否强制通过本地后端代理接口代理传输加载所有图片 (true/false，默认为 false)
PROXYALLIMG=false

# 可选：第三方有害内容鉴黄及图像内容分类过滤审核接口
# ModerateContentApiKey=
# RATINGAPI=


# ==========================================
# Telegram 频道存储通道配置项
# ==========================================

# 仅在您选择将 TG 频道 (TG_Channel) 作为指定存储通道时必须配置
TG_BOT_TOKEN=
TG_CHAT_ID=
