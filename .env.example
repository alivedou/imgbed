# ==========================================
# Next-Auth (Authentication) Configuration
# ==========================================

# REQUIRED: Next-Auth secret key (used for encrypting/signing session tokens)
# Generate a secure random block of text or secret string here.
AUTH_SECRET=00Fv/YUm0enwy04IgP4KoNOWLODe2iJ1tvBzr+4kEZ8=

# Optional: Next-Auth canonical URL of the application
# AUTH_URL=https://your-domain.com

# Optional: Custom admin username and password (defaults to 'admin' / 'admin' if empty)
BASIC_USER=admin
BASIC_PASS=admin

# Optional: Custom visitor username and password (defaults to 'user' / 'user' if empty)
REGULAR_USER=user
REGULAR_PASS=user


# ==========================================
# Feature Flags & API Settings
# ==========================================

# Whether to enable visitor authentication for upload features (true/false, defaults to false)
ENABLE_AUTH_API=false

# Whether to proxy all images through local backend (true/false, defaults to false)
PROXYALLIMG=false

# Optional: For image content classification and censorship
# ModerateContentApiKey=
# RATINGAPI=


# ==========================================
# Telegram Integration Channel Configuration
# ==========================================

# Required only if you select TG_Channel as your upload channel
TG_BOT_TOKEN=
TG_CHAT_ID=
