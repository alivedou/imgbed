{
  "name": "image-nextjs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cf-build": "npx @opennextjs/cloudflare && mv .open-next/worker.js .open-next/_worker.js && cp -r .open-next/assets/_next .open-next/_next && cp _routes.json .open-next/_routes.json",
    "d1": "wrangler d1 execute img --local --file=./tgimglog.sql",
    "d1:deploy": "wrangler d1 execute <DATABASE_NAME_OR_BINDING> --remote --file=./tgimglog.sql"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.6.0",
    "@fortawesome/free-brands-svg-icons": "^6.6.0",
    "@fortawesome/free-regular-svg-icons": "^6.6.0",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@next/third-parties": "14.2.29",
    "@opennextjs/cloudflare": "0.3.1",
    "next": "14.2.29",
    "next-auth": "^5.0.0-beta.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-photo-view": "^1.2.6",
    "react-toastify": "^10.0.6",
    "wrangler": "^3.101.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.29",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
